; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[aether_kiri]

game_path=""

[application]

config/name="AetherKiri"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.6")
config/icon="res://assets/icon.png"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/window_width_override=2240
window/size/window_height_override=1260
window/dpi/allow_hidpi=true
window/stretch/mode="disabled"

[editor_plugins]

enabled=PackedStringArray()

[rendering]

renderer/rendering_method="mobile"
renderer/rendering_method.mobile="mobile"
renderer/rendering_method.android="gl_compatibility"
renderer/rendering_method.web="gl_compatibility"
rendering_device/driver.ios="metal"
rendering_device/driver.android="opengl3"
textures/canvas_textures/default_texture_filter=0
textures/vram_compression/import_etc2_astc=true
